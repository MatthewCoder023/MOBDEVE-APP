<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera is used for QR check-in scanning; not required so the app still
         installs on camera-less devices (the simulate flow covers those). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <!-- Backup stays off until there is a deliberate policy for what user data
         (e.g. future session tokens or preferences) may leave the device. -->
    <application
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.UniSync"
        tools:targetApi="tiramisu">
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <!-- Launcher: the SplashScreen API replaces the old delay-based
             SplashActivity, so auth is the first real screen. -->
        <activity
            android:name=".AuthActivity"
            android:exported="true"
            android:theme="@style/Theme.UniSync.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
