<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- DayNight with full night resources (values-night/). Status/navigation bar
         colors come from enableEdgeToEdge() in code; the XML attributes for them
         are deprecated as of API 35. -->
    <style name="Theme.UniSync" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/dark_green</item>
        <item name="colorSecondary">@color/light_green</item>
        <item name="android:colorAccent">@color/dark_green</item>
        <item name="materialButtonStyle">@style/Widget.UniSync.Button</item>
    </style>

    <!-- Launch theme for the SplashScreen API; swaps to Theme.UniSync once the
         first frame is ready. Brand green in both light and dark mode. -->
    <style name="Theme.UniSync.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/dark_green</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_monogram</item>
        <item name="postSplashScreenTheme">@style/Theme.UniSync</item>
    </style>

    <!-- App-wide button shapes so layouts stop repeating tint/corner attributes. -->
    <style name="Widget.UniSync.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/dark_green</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.UniSync.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Shared text styles so screens stay consistent; use these instead of
         repeating textColor/textSize/textStyle triplets in layouts. -->
    <style name="TextAppearance.UniSync.ScreenTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/dark_gray_text</item>
    </style>

    <style name="TextAppearance.UniSync.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/muted_text</item>
    </style>

    <style name="TextAppearance.UniSync.CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/dark_gray_text</item>
    </style>

    <style name="TextAppearance.UniSync.CardSubtitle" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/muted_text</item>
    </style>
</resources>
