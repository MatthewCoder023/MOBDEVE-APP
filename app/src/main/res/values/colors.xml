<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- dark_green doubles as a container color (buttons, launcher icon) and is
         intentionally NOT themed for night. For green text/icons use
         brand_accent, which lightens in dark mode. "white" stays literal white
         (text on green surfaces); use "surface" for card/nav backgrounds. -->
    <color name="dark_green">#006B3C</color>
    <color name="light_green">#6FCF97</color>
    <color name="brand_accent">#006B3C</color>
    <color name="background">#F7F9F8</color>
    <color name="surface">#FFFFFF</color>
    <color name="dark_gray_text">#222222</color>
    <color name="white">#FFFFFF</color>
    <!-- Darkened from #66756D: that shade was ~4.6:1 against the app background,
         barely past the 4.5:1 WCAG AA line; this one is ~5.5:1. -->
    <color name="muted_text">#5A6961</color>
    <color name="soft_line">#DDE7E1</color>
</resources>
