<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night overrides: a lighter primary so M3 components (switches, checkboxes,
         text fields) stay visible on dark surfaces, and dark status-bar icons off. -->
    <style name="Theme.UniSync" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/light_green</item>
        <item name="colorSecondary">@color/light_green</item>
        <item name="android:colorAccent">@color/light_green</item>
    </style>
</resources>
