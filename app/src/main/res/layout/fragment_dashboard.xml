<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Text set at runtime: time-of-day greeting with the profile name. -->
        <TextView
            android:id="@+id/greetingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:accessibilityHeading="true"
            android:textColor="@color/dark_gray_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/dashboard_subtitle"
            android:textAppearance="@style/TextAppearance.UniSync.Subtitle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_green_gradient"
            android:elevation="@dimen/card_elevation"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_next_class_label"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- Text set at runtime from the schedule data. -->
            <TextView
                android:id="@+id/nextClassValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:columnCount="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openCrowdButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/shortcut_crowd"
                android:textColor="@color/brand_accent"
                app:backgroundTint="@color/surface"
                app:icon="@drawable/ic_crowd"
                app:iconTint="@color/brand_accent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openQrButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="6dp"
                android:text="@string/title_qr"
                android:textColor="@color/brand_accent"
                app:backgroundTint="@color/surface"
                app:icon="@drawable/ic_qr"
                app:iconTint="@color/brand_accent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openNotificationsButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="6dp"
                android:text="@string/shortcut_alerts"
                android:textColor="@color/brand_accent"
                app:backgroundTint="@color/surface"
                app:icon="@drawable/ic_alerts"
                app:iconTint="@color/brand_accent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openScheduleButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="6dp"
                android:layout_marginTop="12dp"
                android:text="@string/nav_schedule"
                android:textColor="@color/brand_accent"
                app:backgroundTint="@color/surface"
                app:icon="@drawable/ic_nav_schedule"
                app:iconTint="@color/brand_accent" />
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:accessibilityHeading="true"
            android:text="@string/dashboard_today"
            android:textColor="@color/dark_gray_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/dashboardRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />
    </LinearLayout>
</ScrollView>
